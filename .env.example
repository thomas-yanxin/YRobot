# MiniCPM-o 4.5 Realtime Gateway. Its default deployment is HTTPS/WSS, and a
# bare host is normalized to wss://HOST/v1/realtime?mode=video.
YROBOT_REALTIME_URL=wss://10.0.16.184:8006/v1/realtime?mode=video

# The current LAN Gateway presents MiniCPM-o-Demo's self-signed certificate.
# Keep this at 0 for that certificate; reissue one with a matching IP/DNS SAN
# and a trusted chain, then use 1 for production or any untrusted network.
YROBOT_TLS_VERIFY=0

# Attach the latest Reachy JPEG to each one-second microphone unit.
YROBOT_SEND_VIDEO=1

# Fetch and cache /api/default_ref_audio, then request spoken model output.
YROBOT_ENABLE_TTS=1

# One startup listen unit avoids clipping the user's opening words without the
# upstream default three-second delay. The current comni backend accepts this
# through the runtime protocol.
YROBOT_FORCE_LISTEN_COUNT=1
YROBOT_LENGTH_PENALTY=1.1

# Realtime video sessions are limited to 300 seconds. Roll over beforehand.
YROBOT_SESSION_ROLLOVER=285
YROBOT_RECONNECT_INITIAL=0.5
YROBOT_RECONNECT_MAX=8

LOG_LEVEL=INFO
