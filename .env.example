# ============================================================================
# Reachy Mini Live Chat — configuration
# Copy to `.env` and edit. All values are optional; sensible defaults apply.
# ============================================================================

# ---- Language -------------------------------------------------------------
LANG=auto                       # auto | zh | en

# ---- Conversational VLM: MiniCPM-V-4.6 via llama.cpp (OpenAI-compatible) ---
# Serves BOTH text and vision turns locally. Start llama.cpp's multimodal server
# (first run auto-downloads the model + mmproj vision projector, ~2-3 GB):
#   llama-server -hf openbmb/MiniCPM-V-4.6-gguf:Q4_K_M --reasoning off --host 0.0.0.0 --port 8080 -c 4096
# --reasoning off disables MiniCPM-V's thinking trace (needed for low latency; vision still works).
# (scripts/setup_mac.sh installs llama.cpp; brew install llama.cpp if you skipped it.)
LLM_BASE_URL=http://localhost:8080/v1
LLM_MODEL=openbmb/MiniCPM-V-4.6-gguf
LLM_API_KEY=not-needed

# ---- Vision turns (gated keyframes) ---------------------------------------
# Default = the SAME local MiniCPM-V server above (images understood locally).
VISION_BASE_URL=http://localhost:8080/v1
VISION_MODEL=openbmb/MiniCPM-V-4.6-gguf
VISION_API_KEY=not-needed
# To offload image turns to a cloud VLM instead (optional), e.g. ModelScope:
#   VISION_BASE_URL=https://api-inference.modelscope.ai/v1
#   VISION_MODEL=Qwen-Ambassador/Qwen3.7-Plus
#   VISION_API_KEY=<your-modelscope-token>

# ---- ASR (FunASR SenseVoice) ----------------------------------------------
ASR_MODEL=iic/SenseVoiceSmall
ASR_DEVICE=cpu                  # cpu | mps

# ---- TTS (Kokoro via mlx-audio) -------------------------------------------
TTS_MODEL=mlx-community/Kokoro-82M-4bit
TTS_VOICE_ZH=zf_xiaobei
TTS_VOICE_EN=af_heart
TTS_SPEED=1.1

# ---- VAD / turn taking ----------------------------------------------------
VAD_THRESHOLD=0.5               # Silero speech probability threshold
VAD_SILENCE_MS=320              # trailing silence that ends a turn
VAD_MIN_SPEECH_MS=200           # ignore blips shorter than this
USE_SEMANTIC_TURN=0             # 1 = also use livekit/turn-detector to avoid false endpoints

# ---- Full-duplex / barge-in -----------------------------------------------
ENABLE_AEC=0                    # 1 = WebRTC acoustic echo cancellation (true barge-in)
BARGE_IN_ENERGY=0.02            # RMS gate for interrupting the robot while it speaks

# ---- Vision gating (token saving) -----------------------------------------
ENABLE_VISION=1
VISION_MAX_EDGE=768             # resize long edge before sending
VISION_JPEG_QUALITY=75
VISION_PHASH_THRESHOLD=8        # Hamming distance for scene-change detection

# ---- Motion / expressivity ------------------------------------------------
ENABLE_MOTION=1
ENABLE_DOA=1                    # turn head toward the speaker
EMOTIONS_DATASET=pollen-robotics/reachy-mini-emotions-library
CONTROL_HZ=100

# ---- Web UI ---------------------------------------------------------------
WEB_UI=1
WEB_PORT=8042
