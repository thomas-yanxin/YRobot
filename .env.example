# MiniCPM-o 4.5 Video Realtime API.
YROBOT_REALTIME_URL=wss://minicpmo45.modelbest.cn/v1/realtime?mode=video
YROBOT_TLS_VERIFY=1

# Keep responses short so a live robot remains interruptible and natural.
# YROBOT_SYSTEM_PROMPT=你是 Reachy Mini，请自然、简洁地与面前的人交流。
YROBOT_LENGTH_PENALTY=1.1
YROBOT_SESSION_SECONDS=285
YROBOT_RECONNECT_MAX_SECONDS=8

# Reachy local playback. Output is lossless and paced to a 120 ms device lead.
YROBOT_PLAYBACK_PREROLL_MS=0
YROBOT_MIC_CHANNEL=0

# Local near-end speech and echo guard.
YROBOT_VAD_MODE=2
YROBOT_VAD_MIN_RMS=0.006
YROBOT_VAD_NOISE_RATIO=2.2
YROBOT_BARGE_ATTACK_MS=80
YROBOT_BARGE_DEBOUNCE_MS=350
YROBOT_NEAR_END_HOLD_MS=300
# Direct-correlation threshold; a separate short-FIR guard handles filtered echo.
YROBOT_ECHO_CORRELATION=0.72

# Camera, DoA, and motion control.
YROBOT_CAMERA_WIDTH=640
YROBOT_CAMERA_JPEG_QUALITY=72
YROBOT_CAMERA_FPS=1
# Capture and model uplink both run at 1 fps by default.
YROBOT_VISION_SEND_INTERVAL_SECONDS=1
# Active rate after near-end speech; idle polling is 2 Hz.
YROBOT_DOA_HZ=10
YROBOT_DOA_HOLD_SECONDS=3
YROBOT_MOTION_HZ=50

YROBOT_LOG_LEVEL=INFO
