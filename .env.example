# YRobot configuration — copy to .env and edit only when needed.

# MiniCPM-o 4.5 video Realtime Gateway. YRobot deliberately normalizes this
# endpoint to /v1/realtime?mode=video; audio mode ignores video_frames.
YROBOT_REALTIME_URL=wss://10.0.16.184:8006/v1/realtime?mode=video

# The current LAN Gateway uses a self-signed certificate.
YROBOT_TLS_VERIFY=0

# Keep the exact duplex-template prompt. Long persona prompts make the
# realtime model substantially less coherent.
YROBOT_SYSTEM_PROMPT=You are a helpful assistant.

# 500 ms lowers input batching latency while keeping the server's duplex
# turn-taking stable. Valid values: 500-1000, in 20 ms increments.
YROBOT_CHUNK_MS=500

# Send a fresh JPEG at most once: 1 fps around speech, one every 5 s while idle.
YROBOT_SEND_VIDEO=1
YROBOT_FRAME_ACTIVE_S=1.0
YROBOT_FRAME_IDLE_S=5.0

# A short bounded lead absorbs network/TTS jitter without the old 250-800 ms
# adaptive preroll. Valid range: 0.020-0.150.
YROBOT_PLAYBACK_LEAD_S=0.120

# Generation and duplex settings forwarded in session.init.
YROBOT_ENABLE_TTS=1
YROBOT_LENGTH_PENALTY=1.1
YROBOT_FORCE_LISTEN_COUNT=1

# Video sessions have a hard 300 s server limit. YRobot starts a clean rollover
# at a quiet turn when the context approaches 8192 tokens, or by 280 s.
YROBOT_KV_SOFT=6500
YROBOT_KV_HARD=7800
YROBOT_SESSION_ROLLOVER=280
YROBOT_RECONNECT_INITIAL=1.0
YROBOT_RECONNECT_MAX=8.0

LOG_LEVEL=INFO
