# YRobot configuration — copy to .env and edit. Everything is optional.

# MiniCPM-o 4.5 realtime gateway. Any ?mode= in the URL is REPLACED by
# YROBOT_MODE. mode=audio still accepts video frames and doubles the session
# cap (600 s vs 300 s), so it is the default.
YROBOT_REALTIME_URL=wss://10.0.16.184:8006/v1/realtime
YROBOT_MODE=audio
# The LAN gateway serves a self-signed certificate → keep 0 there.
YROBOT_TLS_VERIFY=0

# The duplex model is trained with this exact system sentence (server default
# and official presets). Don't replace it with a persona essay — the Qwen3
# base drifts out of its duplex distribution and leaks <think> blocks.
# Behaviour guidance belongs in the SHORT separate instruction below, which
# is appended after the system sentence on its own line.
#YROBOT_SYSTEM_PROMPT=You are a helpful assistant.
#YROBOT_INSTRUCTION=请像朋友聊天一样简短口语化地回复，跟随用户使用中文或英文。

# Uplink pacing. 500 ms halves reply latency vs 1000 ms; below 500 the server's
# turn-taking misfires (answers before the user finishes) — measured live.
YROBOT_CHUNK_MS=500

# Camera frames ride along with mic chunks. Vision costs ~64 kv-tokens per
# frame out of the 8192 session budget, so cadence adapts: fast while someone
# is talking, sparse when idle.
YROBOT_SEND_VIDEO=1
YROBOT_FRAME_ACTIVE_S=1.0
YROBOT_FRAME_IDLE_S=5.0

# Session rotation: the kv cache degrades past 8192 and creating a session
# takes ~14 s, so rotate early at quiet moments (soft) or immediately (hard).
YROBOT_KV_SOFT=6500
YROBOT_KV_HARD=7800
#YROBOT_SESSION_MAX_S=0      # 0 = auto (audio 570 / video 280)
YROBOT_RECONNECT_INITIAL=2.0 # the server rejects instant reconnects
YROBOT_RECONNECT_MAX=8

# Generation config forwarded in session.init.
YROBOT_LENGTH_PENALTY=1.1
YROBOT_FORCE_LISTEN_COUNT=1
#YROBOT_TEMPERATURE=0        # 0 = server default
#YROBOT_TOP_P=0

# Voice gate on the AEC'd mic (the only robot-voice-free signal — the XVF3800
# "speech" flag is pre-AEC and must never drive barge-in).
YROBOT_GATE_RATIO=4.0
YROBOT_GATE_MIN_RMS=0.010
YROBOT_GATE_BARGE_MULT=1.5
YROBOT_ONSET_MS=100
YROBOT_BARGE_ONSET_MS=120
YROBOT_RELEASE_MS=400

# Uplink AGC (gain-up only) so quiet speakers still get answers.
YROBOT_AGC_TARGET_RMS=0.12
YROBOT_AGC_MAX_GAIN=6.0

# Playback: each utterance starts after an adaptive preroll that absorbs the
# server's TTS supply jitter (underruns grow it, clean turns shrink it), and
# the device-side queue is capped so a barge-in flush stays cheap.
YROBOT_PREROLL_MIN_S=0.25
YROBOT_PREROLL_MAX_S=0.8
YROBOT_MAX_BACKLOG_S=1.5

# Barge-in turn gate. Unlatching needs YROBOT_UNLATCH_LISTENS consecutive
# clean listens (user quiet >= QUIET_S, not just an ack of our own force,
# no model audio in between) — a single listen is exactly what precedes a
# monologue resumption.
YROBOT_QUIET_S=0.7
YROBOT_UNLATCH_LISTENS=2
YROBOT_REFORCE_ACK_S=1.2
YROBOT_HOLD_MAX_S=12
YROBOT_REFORCE_S=1.0

# Motion.
YROBOT_MOTION=1
YROBOT_MOTION_HZ=20
YROBOT_TRACK_IDLE=0.4
YROBOT_TRACK_LISTEN=0.6
YROBOT_TRACK_SPEAK=0.25
YROBOT_DOA=1

LOG_LEVEL=INFO
