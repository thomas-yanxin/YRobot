# Raw llama-omni-server endpoint. `/backend` is added when the path is omitted.
OMNI_WS_URL=wss://10.0.16.184:28099/backend

# The LAN server currently uses a self-signed certificate.
# Set to 1 only after installing a trusted certificate on the server.
OMNI_TLS_VERIFY=0

# Send the latest Reachy camera JPEG with each one-second audio slice.
OMNI_SEND_VIDEO=1

# Values above 1 reduce premature end-of-turn sampling. The upstream full-duplex
# backend commonly uses 1.1.
OMNI_LENGTH_PENALTY=1.1

# Optional spoken persona. Empty uses YRobot's concise bilingual default.
OMNI_SYSTEM_PROMPT=

LOG_LEVEL=INFO
