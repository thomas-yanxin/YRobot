# ============================================================================
# Reachy Mini — Realtime Full-Duplex Audio-Visual Dialogue — configuration
# Copy to `.env` and edit. All values are optional; sensible defaults apply.
# ============================================================================

# ---- Language -------------------------------------------------------------
LANG=auto                       # auto | zh | en  (greeting + motion-cue language hint)

# ---- Omni brain: MiniCPM-o 4.5 via llama.cpp-omni --------------------------
# The conversational model runs remotely and does ASR + reasoning + TTS end-to-end.
# OMNI_WS_URL is the BASE url (scheme://host:port); the path is derived from OMNI_ENDPOINT:
#   gateway → /v1/realtime?mode=<OMNI_GATEWAY_MODE>   (MiniCPM-o-Demo gateway.py, e.g. :8006)
#   backend → /backend                               (raw llama-omni-server, e.g. :28099)
# If OMNI_WS_URL already includes a path, it's used verbatim. Self-signed certs are common.
OMNI_WS_URL=wss://10.0.16.187:8006
OMNI_ENDPOINT=gateway           # gateway (MiniCPM-o-Demo :8006) | backend (raw llama-omni-server)
OMNI_GATEWAY_MODE=video         # gateway only: video = audiovisual | audio = audio-only | chat = turn-based
OMNI_MODE=full_duplex           # session.init protocol mode: full_duplex (realtime) | turn_based
OMNI_USE_TTS=1                  # 1 = model speaks (server-side TTS)
OMNI_TLS_INSECURE=1             # 1 = don't verify the TLS cert (self-signed)
OMNI_SESSION_READY_S=60         # wait this long for session.created (gateway queue + model cold start)
# System persona. Keep it spoken/concise; do NOT ask for markdown or tags — the model
# speaks its text verbatim, so any tag would be read aloud. Leave blank to use the default.
OMNI_SYSTEM_PROMPT=
# Optional reference .wav to clone the robot's spoken voice (path on this machine).
OMNI_VOICE_REF=

# ---- Omni audio/video timing ----------------------------------------------
OMNI_CHUNK_MS=1000              # audio per input.append (the model's 1 Hz period)
# Output PCM sample rate. The server doesn't report it; MiniCPM-o token2wav is ~24 kHz.
# If the played voice sounds pitched up/sped, set this to 16000.
OMNI_OUT_SR=24000
# Echo / noise / gain — done in HARDWARE by the ReSpeaker XVF3800 mic board (always on),
# exactly like the official Reachy Mini app. No software AEC.
OMNI_RESPEAKER_CONFIG=1         # write tuned XVF3800 params (AEC/NS/AGC) at startup — leave on
OMNI_RECONNECT_S=1.5            # reconnect backoff after a dropped WebSocket
# Diagnostics: set to a path (e.g. /tmp/uplink.raw) to record exactly what the model
# hears (raw s16le mono 16 kHz). Play back: ffplay -f s16le -ar 16000 -i /tmp/uplink.raw
OMNI_DUMP_UPLINK=
# Fixed software mic gain before VAD + uplink (clipped to ±1). The XVF3800 does AGC in
# hardware, but if speech reaches the model too quiet (rms peak <~0.08 while talking →
# it only listens), try 2.0-4.0. A constant gain does not affect the ratio-based VAD.
OMNI_MIC_GAIN=1.0
# Software AGC on the uplink ONLY (the VAD sees the raw mic): frames the VAD marks as
# speech are normalized toward OMNI_MIC_AGC_TARGET rms, never attenuated, capped at
# OMNI_MIC_AGC_MAX_GAIN. This is the robust fix for "I talk but it never answers".
OMNI_MIC_AGC=1
OMNI_MIC_AGC_TARGET=0.12
OMNI_MIC_AGC_MAX_GAIN=8.0
# On barge-in, immediately ship the partial (<1 s) capture buffer with force_listen so
# the server stops generating up to ~1 s sooner (0 = wait for the chunk boundary).
OMNI_BARGE_FLUSH=1
OMNI_PLAYBACK_CHUNK_MS=60       # speaker push size; bigger = fewer wake-ups (smoother on CM4)
OMNI_PLAYBACK_CUSHION_MS=200    # keep this much audio buffered ahead — absorbs CPU jitter
                                # (raise to 300-400 if speech still stutters; adds a little latency)
OMNI_SEND_VIDEO=1               # attach a current camera frame to input.append
OMNI_VIDEO_EVERY_N=1            # attach a frame every Nth chunk. Raise (e.g. 3) if the
                                # server can't sustain vision+audio at real time (choppy/lag).
OMNI_VIDEO_FPS=1.0
OMNI_VIDEO_MAX_EDGE=448         # resize long edge before JPEG
OMNI_VIDEO_JPEG_QUALITY=70

# ---- Omni sampling (optional; blank = model default) ----------------------
OMNI_TEMPERATURE=
OMNI_TOP_P=
OMNI_TOP_K=
OMNI_LISTEN_PROB_SCALE=         # <1 makes the model SPEAK more (try 0.3 if it only listens); >1 = listen more
OMNI_FORCE_LISTEN_COUNT=        # force N listen steps at the start of each turn
OMNI_MAX_SPEAK_TOKENS_PER_CHUNK=
OMNI_TTS_TEMPERATURE=

# ---- Local VAD (drives DOA head-turn / listen mood / barge-in only) -------
# Adaptive energy gate on the AEC'd mic — the only signal free of the robot's own
# voice, so energy during playback = a human (this is what makes barge-in work).
# The XVF3800's own speech flag is PRE-AEC (hears the robot's speaker + servos) and
# is only used for the DOA angle.
VAD_THRESHOLD=0.5               # speech gate: RMS must exceed ~(2.5+6*thr)x the noise floor
VAD_SILENCE_MS=320              # trailing silence that marks end of human speech
VAD_MIN_SPEECH_MS=200           # ignore blips shorter than this
VAD_BARGE_MIN_SPEECH_MS=100     # faster onset gate while the robot talks = barge-in speed

# ---- Motion / expressivity ------------------------------------------------
ENABLE_MOTION=1
ENABLE_DOA=1                    # turn head toward the speaker (mic-array DOA)
# Daemon-native motion (auto-detected; both fall back to app-level equivalents on
# older SDKs). WOBBLE = speech-synced head motion timed to the actual audio clock;
# FACE_TRACKING = look at the person even when nobody talks (paused while speaking).
ENABLE_DAEMON_WOBBLE=1
ENABLE_FACE_TRACKING=1
EMOTIONS_DATASET=pollen-robotics/reachy-mini-emotions-library
CONTROL_HZ=30                   # motion loop rate; 30 is fluid (EMA-smoothed) + light on the CM4

# ---- Web UI ---------------------------------------------------------------
WEB_UI=1
WEB_PORT=8042
