# MiniCPM-o 4.5 realtime gateway. A bare host is normalized to
# wss://HOST/v1/realtime?mode=audio (audio mode: 600 s sessions, and the
# gateway still accepts camera frames in it).
# Official cloud endpoint:
#YROBOT_REALTIME_URL=minicpmo45.modelbest.cn
# Self-hosted LAN gateway (MiniCPM-o-Demo, self-signed certificate):
YROBOT_REALTIME_URL=wss://10.0.16.184:8006/v1/realtime
YROBOT_TLS_VERIFY=0

# Persona: ONE short line. It is appended after the trained system line —
# long free-form personas drift the model out of its duplex distribution.
#YROBOT_PERSONA=你是 Reachy，一个友好的桌面机器人，用对方的语言简短口语化地回复。

# Attach camera frames to the uplink (1 fps in conversation, 0.2 fps idle,
# never while only the robot is speaking).
YROBOT_SEND_VIDEO=1

# Session rotation happens at the first quiet moment past either budget.
#YROBOT_SESSION_BUDGET_S=550
#YROBOT_KV_BUDGET=7200

# 0..3; higher = stricter voice detection (2 works well next to motors).
#YROBOT_VAD_AGGRESSIVENESS=2

# Daemon face-tracking blend weight, 0 disables (DoA-only gaze).
#YROBOT_HEAD_TRACKING_WEIGHT=0.4
